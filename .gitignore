# node_modules and the worktree symlinks below use NO trailing slash so the
# pattern matches a symlink too, not only a real directory. Lane worktrees
# symlink these on Linux; a dir-only pattern (trailing slash) would miss the
# symlink and leave every worktree born "dirty", which breaks worktree cleanup.
node_modules
.env
.env.*
!.env.example
*.key
*.pem
client/node_modules
.husky/_
client/build/
server/uploads/*
!server/uploads/.gitkeep
*.log
.DS_Store

# Claude Code / agent runtime artifacts
.playwright-mcp/
.claude/scheduled_tasks.lock
client/.claude/

# UI / pre-deploy review run output
.review-screenshots/

# Loose screenshots at repo root (intentional assets live under client/public/ or client/src/)
/*.png

# Claude Code per-user settings. Contains tool/permission allowlist entries that
# may include developer-specific paths or one-off local-DB connection strings.
# Treat as local-only — don't track. Project-level Claude config lives in
# .claude/settings.json (committed) instead.
.claude/settings.local.json
