{
  "chromePath": "/opt/google/chrome/chrome",
  "accounts": {
    "staff": { "id": 5, "tokenVersion": 0 },
    "client": { "id": 19, "tokenVersion": 0 },
    "hired": { "id": 1488, "tokenVersion": 0 },
    "admin": { "id": 1, "tokenVersion": 0 },
    "applicant": { "id": 4197, "tokenVersion": 0 }
  },
  "pages": [
    { "name": "home", "host": "public.localhost", "path": "/", "auth": "none" },
    { "name": "services", "host": "public.localhost", "path": "/services", "auth": "none",
      "scrollableAllow": [".ws-press-formula"] },
    { "name": "method", "host": "public.localhost", "path": "/method", "auth": "none" },
    { "name": "about", "host": "public.localhost", "path": "/about", "auth": "none" },
    { "name": "faq", "host": "public.localhost", "path": "/faq", "auth": "none" },
    { "name": "labnotes", "host": "public.localhost", "path": "/labnotes", "auth": "none" },
    { "name": "labnotes-post", "host": "public.localhost", "path": "/labnotes/:token", "auth": "none",
      "tokenQuery": "SELECT slug AS token FROM blog_posts WHERE published_at IS NOT NULL ORDER BY published_at DESC LIMIT 1" },
    { "name": "client-login", "host": "public.localhost", "path": "/login", "auth": "none" },
    { "name": "quote", "host": "public.localhost", "path": "/quote", "auth": "none" },
    { "name": "classes", "host": "public.localhost", "path": "/classes", "auth": "none" },

    { "name": "proposal-sent", "host": "public.localhost", "path": "/proposal/:token", "auth": "none", "settleMs": 2600,
      "tokenQuery": "SELECT token FROM proposals WHERE status='sent' ORDER BY id DESC LIMIT 1" },
    { "name": "proposal-paid", "host": "public.localhost", "path": "/proposal/:token", "auth": "none", "settleMs": 2600,
      "tokenQuery": "SELECT token FROM proposals WHERE status='deposit_paid' ORDER BY id DESC LIMIT 1" },
    { "name": "plan-welcome", "host": "public.localhost", "path": "/plan/:token", "auth": "none", "settleMs": 2600,
      "tokenQuery": "SELECT token FROM drink_plans WHERE status='draft' ORDER BY id DESC LIMIT 1" },
    { "name": "invoice", "host": "public.localhost", "path": "/invoice/:token", "auth": "none", "settleMs": 2600,
      "tokenQuery": "SELECT token FROM invoices WHERE status='sent' ORDER BY id DESC LIMIT 1" },
    { "name": "shopping-list", "host": "public.localhost", "path": "/shopping-list/:token", "auth": "none", "settleMs": 2600,
      "tokenQuery": "SELECT token FROM drink_plans WHERE status='reviewed' ORDER BY id DESC LIMIT 1" },

    { "name": "portal-home", "host": "public.localhost", "path": "/my-proposals", "auth": "client", "settleMs": 2600,
      "authAssert": ".cp-tabs", "scrollableAllow": [".cp-tabs"] },
    { "name": "portal-archive", "host": "public.localhost", "path": "/my-proposals/archive", "auth": "client", "settleMs": 2600,
      "authAssert": ".cp-tabs", "scrollableAllow": [".cp-tabs"] },

    { "name": "staff-dashboard", "host": "staff.localhost", "path": "/dashboard", "auth": "staff", "authAssert": ".sp-tabs" },
    { "name": "staff-shifts", "host": "staff.localhost", "path": "/shifts", "auth": "staff", "authAssert": ".sp-tabs" },
    { "name": "staff-shifts-mine", "host": "staff.localhost", "path": "/shifts/mine", "auth": "staff", "authAssert": ".sp-tabs" },
    { "name": "staff-pay", "host": "staff.localhost", "path": "/pay", "auth": "staff", "authAssert": ".sp-tabs" },
    { "name": "staff-tip-card", "host": "staff.localhost", "path": "/tip-card", "auth": "staff", "authAssert": ".sp-tabs" },
    { "name": "staff-account-profile", "host": "staff.localhost", "path": "/account/profile", "auth": "staff",
      "authAssert": ".sp-acc-nav", "scrollableAllow": [".sp-acc-nav"] },
    { "name": "staff-account-payments", "host": "staff.localhost", "path": "/account/payments", "auth": "staff",
      "authAssert": ".sp-acc-nav", "scrollableAllow": [".sp-acc-nav"] },
    { "name": "staff-account-notifications", "host": "staff.localhost", "path": "/account/notifications", "auth": "staff",
      "authAssert": ".sp-acc-nav", "scrollableAllow": [".sp-acc-nav"] },
    { "name": "staff-account-documents", "host": "staff.localhost", "path": "/account/documents", "auth": "staff",
      "authAssert": ".sp-acc-nav", "scrollableAllow": [".sp-acc-nav"] },
    { "name": "staff-account-calendar", "host": "staff.localhost", "path": "/account/calendar", "auth": "staff",
      "authAssert": ".sp-acc-nav", "scrollableAllow": [".sp-acc-nav"] },

    { "name": "hiring-landing", "host": "hiring.localhost", "path": "/", "auth": "none" },
    { "name": "hiring-login", "host": "hiring.localhost", "path": "/login", "auth": "none" },
    { "name": "hiring-register", "host": "hiring.localhost", "path": "/register", "auth": "none" },
    { "name": "hiring-forgot-password", "host": "hiring.localhost", "path": "/forgot-password", "auth": "none" },

    { "name": "onboarding-welcome", "host": "hiring.localhost", "path": "/welcome", "auth": "hired", "authAssert": ".steps-bar" },
    { "name": "onboarding-field-guide", "host": "hiring.localhost", "path": "/field-guide", "auth": "hired", "authAssert": ".steps-bar" },
    { "name": "onboarding-agreement", "host": "hiring.localhost", "path": "/agreement", "auth": "hired", "authAssert": ".steps-bar" },
    { "name": "onboarding-contractor-profile", "host": "hiring.localhost", "path": "/contractor-profile", "auth": "hired", "authAssert": ".steps-bar" },
    { "name": "onboarding-payday-protocols", "host": "hiring.localhost", "path": "/payday-protocols", "auth": "hired", "authAssert": ".steps-bar" },

    { "name": "admin-home", "host": "localhost", "path": "/", "auth": "admin", "settleMs": 2600, "authAssert": ".shell", "reportOnly": true },
    { "name": "admin-events", "host": "localhost", "path": "/events", "auth": "admin", "settleMs": 2600, "authAssert": ".shell", "reportOnly": true },
    { "name": "admin-proposals", "host": "localhost", "path": "/proposals", "auth": "admin", "settleMs": 2600, "authAssert": ".shell", "reportOnly": true },
    { "name": "admin-messages", "host": "localhost", "path": "/messages", "auth": "admin", "settleMs": 2600, "authAssert": ".shell", "reportOnly": true },

    { "name": "apply", "host": "hiring.localhost", "path": "/apply", "auth": "applicant", "authAssert": ".file-upload-area" },
    { "name": "compare", "host": "public.localhost", "path": "/compare/:token", "skipped": "no proposal_groups rows in dev" },
    { "name": "tip", "host": "public.localhost", "path": "/tip/:token", "skipped": "no tip_page_token rows in dev" },
    { "name": "feedback", "host": "public.localhost", "path": "/feedback/:token", "skipped": "same tip-token gap as /tip" },
    { "name": "staff-payout-detail", "host": "staff.localhost", "path": "/pay/:periodId", "skipped": "payouts table empty in dev" },
    { "name": "staff-shift-detail", "host": "staff.localhost", "path": "/shifts/:id", "skipped": "needs a shift the fixture user is rostered on; covered manually" }
  ]
}
