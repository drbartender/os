# Thumbtack harvester agent (box-only). Copy to .env on the box and fill in.

# The os API base. In prod: https://api.drbartender.com
API_BASE_URL=http://localhost:5000
# MUST match THUMBTACK_AGENT_SECRET on the os server.
THUMBTACK_AGENT_SECRET=

# Persistent logged-in Chrome profile. Log into Thumbtack ONCE via RDP into THIS dir
# (using Playwright's launchPersistentContext, not stock desktop Chrome).
CHROME_PROFILE_DIR=/home/drbartender/.thumbtack-profile

# Poll cadence and the human-pace jitter between leads.
POLL_INTERVAL_MS=300000
MIN_DELAY_MS=8000
MAX_DELAY_MS=25000

# Safety caps.
DAILY_CAP=40
BATCH_LIMIT=10
RENDER_TIMEOUT_MS=20000

# Optional: hard-set the pro email to exclude. Default reads it from __NEXT_DATA__.
PRO_EMAIL_OVERRIDE=

# Agent-side kill-switch (the server has one too). 'false' idles the HARVEST side only (the reply queue has its own server-side switch, TT_AUTOREPLY_ENABLED).
HARVESTER_ENABLED=true

# Auto first-reply queue (spec 2026-07-21). The loop ticks at the reply
# cadence; the harvest poll piggybacks every Nth tick to keep its pace above.
REPLY_POLL_INTERVAL_MS=25000
REPLY_DAILY_CAP=40
REPLY_BATCH_LIMIT=3
# Deterministic per-negotiation lead page; {id} is replaced. Tune during the
# live test if TT's path differs (no code change needed).
REPLY_LEAD_URL_TEMPLATE=https://www.thumbtack.com/pro/inbox/{id}
