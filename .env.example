# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/dr_bartender

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Optional: separate signing key for unsubscribe / marketing-link JWTs (365-day lifetime).
# Falls back to JWT_SECRET if unset — set in prod to isolate marketing-token compromise from auth.
UNSUBSCRIBE_SECRET=

# Encryption (for bank account data at rest — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# File Upload
UPLOAD_DIR=./server/uploads
MAX_FILE_SIZE=10485760

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here

# Client (for CORS + admin-facing links — e.g., admin dashboard URLs in admin emails)
CLIENT_URL=http://localhost:3000

# Public site URL (for client-facing token links — proposals, drink plans, invoices, shopping lists)
# Use this domain in any URL that gets sent to a customer. Defaults to https://drbartender.com in prod.
PUBLIC_SITE_URL=http://localhost:3000

# Staff portal origin used in hire-confirmation emails + staff calendar/portal links.
# Defaults to https://staff.drbartender.com in prod when unset.
STAFF_URL=http://localhost:3000

# File Storage (Cloudflare R2)
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=your_bucket_name_here

# Admin Seed Account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
# Optional. E.164 phone for last-minute (<72h) booking SMS alerts to the owner.
# If unset, the admin SMS leg is skipped (the broad staff blast still fires).
ADMIN_PHONE=+1xxxxxxxxxx

# SMS (Twilio)
# TWILIO_AUTH_TOKEN also verifies the inbound-SMS webhook signature (POST /api/sms/inbound).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Payments (Stripe — live mode)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_DEPOSIT_AMOUNT=10000

# Payments (Stripe — test mode, optional)
# When STRIPE_TEST_MODE_UNTIL (ISO 8601 date) is in the future, every Stripe
# call uses the *_TEST credentials below. After the cutoff passes, the next
# request automatically reverts to the live credentials above — no redeploy.
# Example: STRIPE_TEST_MODE_UNTIL=2026-04-21T23:59:59-07:00
STRIPE_SECRET_KEY_TEST=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET_TEST=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_TEST_MODE_UNTIL=

# Tip QR page
# Public Google review destination shown after a tip submission. Set the same
# URL on both server (for emails / token links) and client (REACT_APP_*) sides.
PUBLIC_GOOGLE_REVIEW_URL=https://g.page/r/PLACEHOLDER/review
REACT_APP_GOOGLE_REVIEW_URL=https://g.page/r/PLACEHOLDER/review
# Inbox that receives bartender feedback submissions from the tip thank-you flow
ADMIN_FEEDBACK_NOTIFICATION_EMAIL=contact@drbartender.com

# Thumbtack Integration
THUMBTACK_WEBHOOK_SECRET=your_thumbtack_webhook_secret_here
# Shared secret for the Thumbtack email-harvester agent (box-only poller + the admin
# manual-paste UI). Agent routes at /api/admin/thumbtack FAIL CLOSED (401) in every
# environment when this is unset. Generate a long random value; never commit it.
THUMBTACK_AGENT_SECRET=
# Kill-switch for the harvester. Set to 'false' to make GET /pending-harvest return
# [] (a redeploy-free stop) and to halt the box agent. Defaults on when unset.
HARVESTER_ENABLED=true
# Optional. Retry cap for transient agent failures before a lead is marked failed.
MAX_HARVEST_ATTEMPTS=3
# Optional. Postgres interval before a leased-but-unresolved lead is re-offered.
HARVEST_COOLDOWN_INTERVAL=6 hours

# Google Places API (New) key for venue-name smart search. Server-only.
# When unset, the venue search degrades to a plain text input.
GOOGLE_PLACES_API_KEY=

# Render (auto-set by Render in production — do not set locally)
# RENDER_EXTERNAL_URL=https://your-service.onrender.com

# Backend origin for server-rendered email links (unsubscribe, etc).
# Defaults to RENDER_EXTERNAL_URL in prod; set explicitly if the backend ever
# moves behind a CDN or custom domain.
# API_URL=https://api.drbartender.com

# Sentry — leave unset in dev to disable error reporting
SENTRY_DSN_SERVER=
REACT_APP_SENTRY_DSN_CLIENT=

# Schedulers fire only when NODE_ENV=production (Render sets this by default).
# In any other environment they default to OFF, so the dev server never burns
# Resend/Twilio allotments by iterating the shared Neon DB.
#   RUN_SCHEDULERS=true   force-on locally (testing a handler against a scratch row)
#   RUN_SCHEDULERS=false  force-off on a secondary prod instance to prevent duplicate runs
RUN_SCHEDULERS=

# Real outbound notifications (Resend email + Twilio SMS) fire only when
# NODE_ENV=production by default — same philosophy as RUN_SCHEDULERS — so the
# dev server never burns Resend/Twilio allotments while pointed at the shared
# Neon DB. When gated off, sends take the existing log-and-skip path.
#   SEND_NOTIFICATIONS=true   force real sends locally (e.g. a real send to a scratch row)
#   SEND_NOTIFICATIONS=false  force off everywhere (e.g. a secondary prod instance)
SEND_NOTIFICATIONS=

# ─── Automated Communication: scheduler controls ─────────────────
# Per-scheduler disable: set RUN_<NAME>_SCHEDULER=false to disable a specific one.
# Honored only when schedulers are running (i.e. on prod, or locally with
# RUN_SCHEDULERS=true). When schedulers are globally disabled, these are ignored.
# RUN_AUTOPAY_SCHEDULER=true
# RUN_AUTOCOMPLETE_SCHEDULER=true
# RUN_AUTO_ASSIGN_SCHEDULER=true
# RUN_SEQUENCE_SCHEDULER=true
# RUN_QUOTE_DRAFT_CLEANUP_SCHEDULER=true
# RUN_MESSAGE_DISPATCHER_SCHEDULER=true

# Cal.com webhook signing secret (HMAC-SHA256). Required in prod;
# webhook returns 503 if unset. See docs/superpowers/specs/2026-05-26-cal-com-integration-design.md.
CAL_WEBHOOK_SECRET=

# Cal.com public booking page URL. Hosted: https://cal.com/<username>/<event-type>.
# Self-hosted: https://book.drbartender.com/<event-type>. Optional in dev;
# templates omit the consult line when unset.
CAL_BOOKING_URL=

# Optional. Set to 'false' to disable the hourly webhook_events prune scheduler
# (default on). Honored only when RUN_SCHEDULERS is not 'false'.
RUN_WEBHOOK_EVENTS_PRUNE_SCHEDULER=

# Optional. Set to 'false' to disable the daily pending_email_changes cleanup
# scheduler (default on). Honored only when RUN_SCHEDULERS is not 'false'.
RUN_PENDING_EMAIL_CLEANUP_SCHEDULER=

# Set to false to disable the daily Stripe payout mirror sweep. Default on (prod only, like all schedulers).
RUN_STRIPE_PAYOUT_SWEEP_SCHEDULER=

# Optional. Set to 'false' to disable the 15-min stranded-pending-refund sweep,
# which heals aged 'pending' proposal_refunds rows: it reconciles them against
# Stripe refunds.list (adopting a matching refund) or marks them failed after a
# 30-min age gate. Default on. Honored only when RUN_SCHEDULERS is not 'false'.
RUN_REFUND_PENDING_SWEEP_SCHEDULER=

# Optional. Set to 'false' to disable the VA-calling maintenance scheduler
# (hourly pending_call/call_audit/telegram_update prune + ~6h Telegram webhook
# heartbeat). Default on. Honored only when RUN_SCHEDULERS is not 'false'.
RUN_VA_CALLING_SCHEDULER=

# Optional. Set to 'false' to disable the presence tracker sweep (15 min:
# stale-desk nudge via Telegram/SMS + auto-flip to away on silence).
# Default on. Honored only when RUN_SCHEDULERS is not 'false'.
RUN_PRESENCE_SCHEDULER=

# ─── Web Push (VAPID) — staff portal push notifications (spec §6.17) ──────
# Generate a keypair once with:  npx web-push generate-vapid-keys
# VAPID identifies this app server to the browsers' push services. The PUBLIC
# key is shared with the client (as REACT_APP_VAPID_PUBLIC_KEY); the PRIVATE
# key is server-only — never commit it, never expose it to the client.
# When VAPID_PRIVATE_KEY is unset the push sender fails closed (returns
# vapid_unset) and the server still boots normally — SMS + email keep covering
# every notification. Push is purely additive.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY, exposed to the client build (client/.env*).
REACT_APP_VAPID_PUBLIC_KEY=
# Contact email embedded in the VAPID JWT (mailto:). Defaults to contact@drbartender.com.
VAPID_CONTACT_EMAIL=contact@drbartender.com

# ─── Zul VA Calling (Telegram-triggered Twilio callback bridge) ───────────
# Our PH-based VA (Zul) places/receives US calls via a Twilio callback bridge:
# the OUTBOUND trigger is a Telegram bot message; voice rides her CELL (Twilio
# calls her, she answers, Twilio bridges the second leg to the target with the
# 224 as caller ID). This endpoint dials billed international calls on an
# auto-refill account from external input, so it is a toll-fraud target — every
# guard (secret path + secret_token header + user_id allowlist + US-only NANP
# validation + confirm-before-dial + spend caps) is load-bearing. See
# docs/superpowers/specs/2026-07-01-zul-va-calling-design.md and
# docs/va-calling-runbook.md.

# Telegram Bot API token from @BotFather. When unset, sendTelegramMessage /
# setTelegramWebhook no-op (log + skip) and the outbound trigger is dead.
TELEGRAM_BOT_TOKEN=

# Secret, unguessable URL path segment AND the value compared (constant-time)
# against the X-Telegram-Bot-Api-Secret-Token header on every update. Set the
# SAME value at setWebhook. Never commit it. Generate:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# Numeric Telegram user id of Zul — the ONLY sender allowed to trigger a call.
# BOOTSTRAP: leave UNSET on the first deploy. In bootstrap mode the webhook
# replies to any sender with their own user id and dials nothing. Read Zul's id
# from that reply, set it here, redeploy. Once set, every other sender is a
# silent no-op.
TELEGRAM_ALLOWED_USER_ID=

# The 224 US voice line, strict E.164. Caller ID on Zul's outbound calls AND the
# number clients dial inbound. Voice+SMS capable; no SMS-to-clients from it.
VOICE_CALLER_ID=+12242220082

# Zul's cell, strict E.164 (+63…). The bridge target Twilio calls. NEVER run it
# through normalizePhone (US-centric; it would mangle a PH number). Stored only
# here — never on a DB record, never committed to the repo.
VA_CELL=

# Optional. Set to 'false' to disable the VA-calling scheduler (hourly prune of
# expired pending_call + retention-aged call_audit/telegram_update rows, plus the
# Telegram webhook-heartbeat check). Default on. Honored only when RUN_SCHEDULERS
# is not 'false' (global flag wins).
RUN_VA_CALLING_SCHEDULER=

# Optional spend caps (toll-fraud controls). Defaults shown.
#   VA_CALL_DAILY_CAP       max calls placed per rolling 24h (DB-backed via call_audit)
#   VA_CALL_PER_MIN_CAP     max triggers accepted per minute
#   VA_CALL_TIME_LIMIT_SEC  per-call hard timeLimit on BOTH legs (1800 = 30 min)
#   PENDING_CALL_TTL_SEC    how long a confirm-before-dial pending record lives
VA_CALL_DAILY_CAP=40
VA_CALL_PER_MIN_CAP=5
VA_CALL_TIME_LIMIT_SEC=1800
PENDING_CALL_TTL_SEC=120

# Lead call bridge (real-time first-ring on new Thumbtack leads).
#   LEAD_CALL_ENABLED     kill switch; 'false' disables the trigger entirely
#                         (redeploy-free, HARVESTER_ENABLED precedent). Default on.
#   LEAD_CALL_DAILY_CAP   max attempt chains opened per rolling 24h (toll-fraud
#                         backstop; normal volume is ~2-3 leads/day). Default 25.
LEAD_CALL_ENABLED=
LEAD_CALL_DAILY_CAP=25

# TT auto first-reply (respond-then-ring): the harvester box sends Dallas's
# saved day/night quick reply on every new lead; day-lead calls fire only
# after the reply is confirmed.
#   TT_AUTOREPLY_ENABLED               master switch, DEFAULT OFF ('true' to enable).
#                                      Gates the webhook-tail fork and empties the
#                                      agent offer endpoint. Does NOT gate the sweep.
#   FIRST_REPLY_FALLBACK_MINUTES       day-lead call fires anyway past this (default 3)
#   FIRST_REPLY_CALL_MAX_AGE_MINUTES   freshness bound on callback/sweep calls (default 240)
#   RUN_FIRST_REPLY_FALLBACK_SCHEDULER 'false' disables the 60s sweep (default on)
#   MAX_FIRST_REPLY_ATTEMPTS           offer cap before a reply flips to failed (default 3)
#   FIRST_REPLY_COOLDOWN_INTERVAL      lease re-offer interval (default '10 minutes')
TT_AUTOREPLY_ENABLED=
FIRST_REPLY_FALLBACK_MINUTES=3
FIRST_REPLY_CALL_MAX_AGE_MINUTES=240
RUN_FIRST_REPLY_FALLBACK_SCHEDULER=
MAX_FIRST_REPLY_ATTEMPTS=3
FIRST_REPLY_COOLDOWN_INTERVAL='10 minutes'
