{
  "name": "dr-bartender-onboarding",
  "version": "1.0.0",
  "description": "Dr. Bartender Contractor Onboarding Portal",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm start\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "seed": "node server/db/seed.js",
    "admin:create": "node server/scripts/createAdmin.js",
    "lint": "eslint server/",
    "lint:fix": "eslint server/ --fix",
    "test": "node --test \"server/**/*.test.js\"",
    "audit:check": "npm audit --omit=dev || true",
    "check:filesize": "node scripts/check-file-size.js --all",
    "mobile:check": "node scripts/mobile-capture.js",
    "build:testing-guide": "node scripts/build-testing-guide.js",
    "bugs:list": "node server/scripts/bugsList.js",
    "optimize:assets": "node scripts/optimize-assets.js",
    "worktree:new": "node scripts/worktree-new.js",
    "worktree:rm": "node scripts/worktree-rm.js",
    "lane:status": "node scripts/lane-status.js",
    "where": "node scripts/show-location.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@sentry/node": "^10.49.0",
    "bcryptjs": "2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dompurify": "3.4.11",
    "dotenv": "^16.3.1",
    "express": "4.22.2",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "8.1.0",
    "jsdom": "29.0.1",
    "jsonwebtoken": "9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "8.20.0",
    "resend": "^6.9.4",
    "stripe": "20.4.1",
    "svix": "^1.90.0",
    "twilio": "^5.13.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.0",
    "nodemon": "^3.0.2",
    "playwright-core": "^1.61.1",
    "sharp": "^0.34.5",
    "wawoff2": "^2.0.1"
  },
  "lint-staged": {
    "server/**/*.js": [
      "eslint"
    ]
  },
  "engines": {
    "node": "26.x"
  },
  "overrides": {
    "undici": "^7.28.0",
    "form-data": "^4.0.6"
  }
}
