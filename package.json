{
  "name": "dr-bartender-onboarding",
  "version": "1.0.0",
  "description": "Dr. Bartender Contractor Onboarding Portal",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm start\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "seed": "node server/db/seed.js",
    "lint": "eslint server/",
    "lint:fix": "eslint server/ --fix",
    "audit:check": "npm audit --omit=dev || true",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "twilio": "^5.13.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.0.2"
  },
  "lint-staged": {
    "server/**/*.js": [
      "eslint"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
